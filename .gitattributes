# 统一换行符：所有文本文件在仓库中存储为 LF，签出时按系统默认转换
* text=auto eol=lf

# 明确指定文本文件类型
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# 二进制文件不做转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.pkl binary
*.npy binary
