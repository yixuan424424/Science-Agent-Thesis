# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# 通义千问 API（推荐）
# 申请地址: https://dashscope.console.aliyun.com/
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# 如果使用 OpenAI
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
